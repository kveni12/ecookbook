generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MembershipRole {
  OWNER
  EDITOR
  VIEWER
}

enum RecipeVisibility {
  PRIVATE
  SPACE
}

enum SourceType {
  MANUAL
  SOCIAL
  WEBSITE
  IMPORTED_VIDEO
  FAMILY_ORAL_HISTORY
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String            @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  accounts         Account[]
  sessions         Session[]
  memberships      Membership[]
  recipesCreated   Recipe[]          @relation("RecipeCreatedBy")
  recipesEdited    Recipe[]          @relation("RecipeEditedBy")
  versionsCreated  RecipeVersion[]
  comments         RecipeComment[]
  favorites        RecipeFavorite[]
  personalNotes    PersonalRecipeNote[]
  invitesSent      Invite[]          @relation("InviteSentBy")
  ownedSpaces      CookbookSpace[]   @relation("SpaceOwner")
  authoredCookbooks Cookbook[]       @relation("CookbookCreatedBy")
}

model CookbookSpace {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  coverImage  String?
  ownerId     String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  owner       User          @relation("SpaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships Membership[]
  recipes     Recipe[]
  invites     Invite[]
  cookbooks   Cookbook[]
}

model Membership {
  id        String         @id @default(cuid())
  userId    String
  spaceId   String
  role      MembershipRole
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  space     CookbookSpace  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([userId, spaceId])
}

model Recipe {
  id               String               @id @default(cuid())
  spaceId          String?
  parentRecipeId   String?
  title            String
  subtitle         String?
  story            String?
  prepTimeMinutes  Int?
  cookTimeMinutes  Int?
  totalTimeMinutes Int?
  servings         Int?
  cuisine          String?
  category         String?
  tags             String[]
  mainIngredients  String[]
  dietaryTags      String[]
  coverImage       String?
  sourceLink       String?
  sourceType       SourceType          @default(MANUAL)
  sourcePreview    Json?
  authorName       String?
  visibility       RecipeVisibility    @default(PRIVATE)
  notes            String?
  tips             String?
  lineageNote      String?
  aiSummary        String?
  createdById      String
  lastEditedById   String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  space            CookbookSpace?      @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  parentRecipe     Recipe?             @relation("RecipeForks", fields: [parentRecipeId], references: [id], onDelete: SetNull)
  adaptations      Recipe[]            @relation("RecipeForks")
  createdBy        User                @relation("RecipeCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  lastEditedBy     User                @relation("RecipeEditedBy", fields: [lastEditedById], references: [id], onDelete: Restrict)
  ingredients      RecipeIngredient[]
  steps            RecipeStep[]
  media            RecipeMedia[]
  versions         RecipeVersion[]
  comments         RecipeComment[]
  favorites        RecipeFavorite[]
  personalNotes    PersonalRecipeNote[]
  cookbookRecipes  CookbookRecipe[]

  @@index([spaceId])
  @@index([parentRecipeId])
}

model RecipeIngredient {
  id        String   @id @default(cuid())
  recipeId  String
  position  Int
  quantity  String?
  unit      String?
  item      String
  notes     String?
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId, position])
}

model RecipeStep {
  id          String   @id @default(cuid())
  recipeId    String
  position    Int
  instruction String
  note        String?
  recipe      Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId, position])
}

model RecipeMedia {
  id          String    @id @default(cuid())
  recipeId    String
  type        MediaType
  url         String
  thumbnailUrl String?
  caption     String?
  position    Int       @default(0)
  recipe      Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model RecipeVersion {
  id           String   @id @default(cuid())
  recipeId      String
  createdById   String
  changeSummary String
  snapshot      Json
  createdAt     DateTime @default(now())
  recipe        Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  createdBy     User      @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([recipeId, createdAt])
}

model RecipeComment {
  id         String   @id @default(cuid())
  recipeId   String
  userId     String
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  recipe     Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecipeFavorite {
  id         String   @id @default(cuid())
  recipeId   String
  userId     String
  rating     Int?
  createdAt  DateTime @default(now())
  recipe     Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([recipeId, userId])
}

model PersonalRecipeNote {
  id         String   @id @default(cuid())
  recipeId   String
  userId     String
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  recipe     Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([recipeId, userId])
}

model Cookbook {
  id          String           @id @default(cuid())
  spaceId      String
  createdById  String
  title        String
  subtitle     String?
  description  String?
  intro        String?
  coverImage   String?
  slug         String          @unique
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  space        CookbookSpace   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  createdBy    User            @relation("CookbookCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  recipes      CookbookRecipe[]
}

model CookbookRecipe {
  id          String    @id @default(cuid())
  cookbookId  String
  recipeId    String
  position    Int
  note        String?
  cookbook    Cookbook  @relation(fields: [cookbookId], references: [id], onDelete: Cascade)
  recipe      Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([cookbookId, recipeId])
}

model Invite {
  id          String        @id @default(cuid())
  spaceId      String
  email        String
  role         MembershipRole
  token        String        @unique
  status       InviteStatus  @default(PENDING)
  invitedById  String
  expiresAt    DateTime
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  space        CookbookSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  invitedBy    User          @relation("InviteSentBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([spaceId, email])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
